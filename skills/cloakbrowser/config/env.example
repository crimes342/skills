# 环境变量配置模板
# 用法: cp env.example .env && 编辑 .env

# CloakBrowser 配置
CLOAK_HEADLESS=true
CLOAK_HUMANIZE=true
CLOAK_PROXY=
CLOAK_PROFILE_DIR=/data/cloak_profiles
CLOAK_FINGERPRINT_SEED=
CLOAK_TIMEZONE=Asia/Shanghai
CLOAK_LOCALE=zh-CN
CLOAK_GEOIP=true

# Xvfb 配置（headed 模式时使用）
DISPLAY=:99
XVFB_RESOLUTION=1920x1080x24

# Hermes 配置
HERMES_CLOAK_DIR=/opt/hermes-cloak
